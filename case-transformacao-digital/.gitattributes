# ============================================================
#  Portfólio de Gestão de Projetos — Everton Pereira Santos
#  Ajusta a barra "Languages" do GitHub para refletir o
#  conteúdo real do repositório: DOCUMENTAÇÃO de projetos.
# ============================================================

# Markdown é o "idioma" principal deste portfólio (READMEs,
# Project Charter, WBS, Matriz de Riscos, Post-Mortem, etc.)
*.md linguist-detectable=true
*.md linguist-documentation=false

# Diagramas Mermaid (Gantt, EAP, fluxos) contam como conteúdo
*.mmd linguist-detectable=true

# Templates de issue/PR são documentação de governança,
# não devem inflar a estatística
.github/**  linguist-documentation=true
LICENSE     linguist-generated=true
CHANGELOG.md linguist-documentation=true

# Arquivos gerados/exportados não entram na contagem
*.pdf   linguist-generated=true
*.xlsx  linguist-generated=true
*.pptx  linguist-generated=true
